{
  "manifest_version": 3,
  "name": "Etsy Crawler Bridge",
  "version": "0.1.0",
  "description": "Crawl Etsy listing data from the active Chrome profile and return results to popup or an allowed web app.",
  "icons": {
    "16": "icons/offorest-icon16.png",
    "32": "icons/offorest-icon32.png",
    "48": "icons/offorest-icon48.png",
    "128": "icons/offorest-icon128.png"
  },
  "permissions": [
    "scripting",
    "tabs",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://www.etsy.com/*",
    "https://etsy.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://localhost/*",
        "http://xlap.com.vn/*",
        "https://xlap.com.vn/*",
        "http://*.xlap.com.vn/*",
        "https://*.xlap.com.vn/*",
        "http://xlap.tech/*",
        "https://xlap.tech/*",
        "http://*.xlap.tech/*",
        "https://*.xlap.tech/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Etsy Crawler",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/offorest-icon16.png",
      "32": "icons/offorest-icon32.png",
      "48": "icons/offorest-icon48.png",
      "128": "icons/offorest-icon128.png"
    }
  },
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*",
      "https://localhost/*",
      "http://xlap.com.vn/*",
      "https://xlap.com.vn/*",
      "http://*.xlap.com.vn/*",
      "https://*.xlap.com.vn/*",
      "http://xlap.tech/*",
      "https://xlap.tech/*",
      "http://*.xlap.tech/*",
      "https://*.xlap.tech/*"
    ]
  }
}
