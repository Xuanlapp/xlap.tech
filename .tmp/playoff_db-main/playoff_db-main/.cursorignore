# Laravel 依赖目录
/vendor/
/node_modules/

# Laravel 缓存和编译文件
/bootstrap/cache/*
!/bootstrap/cache/.gitignore
/storage/framework/cache/*
!/storage/framework/cache/.gitignore
/storage/framework/sessions/*
!/storage/framework/sessions/.gitignore
/storage/framework/testing/*
!/storage/framework/testing/.gitignore
/storage/framework/views/*
!/storage/framework/views/.gitignore
/storage/app/*
!/storage/app/.gitignore
/storage/logs/*
!/storage/logs/.gitignore

# 公共构建目录
/public/build/
/public/hot/
/public/storage/
/public/css/
/public/js/
/public/mix-manifest.json

# 前端构建输出
/public/dist/
/resources/dist/

# 环境文件
.env
.env.backup
.env.production
.phpunit.result.cache

# Laravel Mix / Vite 构建文件
/public/hot
/public/mix-manifest.json
/public/build

# 编辑器和IDE文件
/.idea/
/.vscode/
*.sublime-project
*.sublime-workspace
.phpstorm.meta.php
_ide_helper.php
_ide_helper_models.php

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 本地配置文件
.env.local
.env.development.local
.env.test.local
.env.production.local

# 系统文件
.DS_Store
Thumbs.db

# 测试覆盖率报告
/coverage/
.phpunit.cache/

# Livewire 临时文件
/storage/framework/livewire-tmp/
/storage/framework/laravel-excel/

# 大型二进制文件和数据文件
*.zip
*.tar.gz
*.tgz
*.rar
*.7z
*.pdf
*.mp4
*.mp3
*.mov
*.avi
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.woff
*.woff2
*.eot
*.ttf
*.otf

# 数据库文件
*.sqlite
*.sqlite3
*.db

# 临时文件
/tmp/
/temp/

# 编译后的 JavaScript 和 CSS
/public/css/app.css
/public/js/app.js
/public/mix-manifest.json

# Laravel Telescope
/storage/telescope/

# Laravel Horizon
/storage/horizon/ 